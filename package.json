{
  "name": "oasisrentalmanagementapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:integration": "vitest --config vitest.integration.config.js",
    "test:integration:run": "vitest run --config vitest.integration.config.js",
    "test:integration:seed": "node tests/integration/bootstrapLocalSupabase.mjs",
    "test:integration:file": "vitest run --config vitest.integration.config.js",
    "test:integration:name": "vitest run --config vitest.integration.config.js",
    "test:integration:verbose": "vitest run --config vitest.integration.config.js --reporter=verbose",
    "test:staging": "vitest --config vitest.staging.config.js",
    "test:staging:run": "vitest run --config vitest.staging.config.js",
    "test:staging:file": "vitest run --config vitest.staging.config.js",
    "schema:baseline:refresh": "node scripts/schema/refresh-baseline.mjs refresh",
    "schema:baseline:check": "node scripts/schema/refresh-baseline.mjs check",
    "guardrails:install": "bash scripts/git-guardrails/install-local-hooks.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/vite": "^4.1.18",
    "lucide-react": "^0.560.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1",
    "stripe": "^20.4.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "supabase": "^2.82.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}
