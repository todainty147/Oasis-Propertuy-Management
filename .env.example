# Copy this file to `.env` for local development and fill in non-production values.
# Do not commit real hosted project URLs, anon keys, service-role keys, or tunnel URLs.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_local_supabase_anon_key
APP_URL=http://localhost:5173
ALLOWED_APP_ORIGINS=http://localhost:5173
VITE_USE_BRANDED_INVITES=false
VITE_ENABLE_HOSTED_SECURITY_LOG_SINK=false
VITE_HOSTED_SECURITY_LOG_FUNCTION=ingest-security-observability

# Checkatrade Affiliate API — server-side only (Edge Function env vars, never VITE_ prefixed).
# Obtain credentials from the Checkatrade Developer Portal.
# Leave blank locally; the Edge Function will return a scaffold_ready / manual_follow_up response.
CHECKATRADE_API_KEY=
CHECKATRADE_API_SECRET=
# staging | production  (defaults to staging when unset)
CHECKATRADE_ENV=staging
# Optional: override the submission endpoint URL for local mocking (e.g. http://localhost:8787/mock-checkatrade)
CHECKATRADE_SUBMISSION_URL=
