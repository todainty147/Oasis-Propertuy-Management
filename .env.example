# Copy this file to `.env` for local development and fill in non-production values.
# Do not commit real hosted project URLs, anon keys, service-role keys, or tunnel URLs.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_local_supabase_anon_key
APP_URL=http://localhost:5173
ALLOWED_APP_ORIGINS=http://localhost:5173
VITE_USE_BRANDED_INVITES=false
VITE_ENABLE_HOSTED_SECURITY_LOG_SINK=false
VITE_HOSTED_SECURITY_LOG_FUNCTION=ingest-security-observability
